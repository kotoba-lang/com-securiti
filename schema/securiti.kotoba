// Securiti clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace securiti {

    entity DataSubject {
        id: string @unique
        email: string
        jurisdiction: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity ConsentRecord {
        id: string @unique
        subjectId: string
        purpose: string
        granted: boolean
        recordedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Request {
        id: string @unique
        subjectId: string
        type: string
        status: string
        dueAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Control {
        id: string @unique
        framework: string
        name: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Evidence {
        id: string @unique
        controlId: string
        name: string
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Assessment {
        id: string @unique
        name: string
        riskLevel: string
        completedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
